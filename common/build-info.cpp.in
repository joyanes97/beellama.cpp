#include "build-info.h"

#include "ggml.h"

#include <cstdio>
#include <string>

int LLAMA_BUILD_NUMBER = @LLAMA_BUILD_NUMBER@;
char const * LLAMA_COMMIT = "@LLAMA_BUILD_COMMIT@";
char const * LLAMA_COMPILER = "@BUILD_COMPILER@";
char const * LLAMA_BUILD_TARGET = "@BUILD_TARGET@";
int LLAMA_BUILD_DIRTY = @LLAMA_BUILD_DIRTY@;

int llama_build_number(void) {
    return LLAMA_BUILD_NUMBER;
}

const char * llama_commit(void) {
    return LLAMA_COMMIT;
}

const char * llama_compiler(void) {
    return LLAMA_COMPILER;
}

const char * llama_build_target(void) {
    return LLAMA_BUILD_TARGET;
}

const char * llama_build_info(void) {
    static std::string s = "b" + std::to_string(LLAMA_BUILD_NUMBER) + "-" + LLAMA_COMMIT + (LLAMA_BUILD_DIRTY ? "-dirty" : "");
    return s.c_str();
}

void llama_print_build_info(void) {
    fprintf(stderr, "%s: build = %d (%s)%s\n", __func__, llama_build_number(), llama_commit(), LLAMA_BUILD_DIRTY ? "-dirty" : "");
    fprintf(stderr, "%s: built with %s for %s\n", __func__, llama_compiler(), llama_build_target());
    fprintf(stderr, "%s: ggml op count = %d\n", __func__, GGML_OP_COUNT);
}
